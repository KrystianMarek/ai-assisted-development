
# Beads / Dolt files (added by bd init)
# The whole .beads/ tree is per-project state generated by `bd init`
# and contains a project-specific sync.remote URL — regenerate, don't share.
.beads/
.dolt/
*.db
.beads-credential-key

# Claude Code per-user local settings (permissions, etc.)
.claude/settings.local.json

# Agent conversation memory (per-machine, not shared)
.remember/
